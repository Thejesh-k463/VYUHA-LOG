{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vyuha",
  "version": "2.65.0",
  "identifier": "in.vyuha.tradejournal",
  "build": {
    "frontendDist": "./loading",
    "beforeBuildCommand": "npm run build && npm run desktop:bundle"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vyuha — Trade Journal",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGRkFGMUI0OTFFQUQyRjAKUldUdzB1cVJ0UEg2ajFzRGEwUGZyVFBzMDMyd2owZ3NTcXBuUnR2eEhsSlVLNFBSTFlOV2dXS3MK",
      "endpoints": [
        "https://github.com/Thejesh-k463/VYUHA-LOG/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../desktop-dist": "server"
    }
  }
}
